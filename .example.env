# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_PREFETCH_COUNT=20

# RabbitMQ Checkin Events
RABBITMQ_CHECKIN_EXCHANGE=attendance.events
RABBITMQ_CHECKIN_QUEUE=attendance.checkin.queue
RABBITMQ_CHECKIN_ROUTING_KEY=attendance.checkin.requested

# RabbitMQ Retry & Dead Letter
RABBITMQ_CHECKIN_RETRY_EXCHANGE=attendance.retry
RABBITMQ_CHECKIN_RETRY_QUEUE=attendance.checkin.retry.queue
RABBITMQ_CHECKIN_RETRY_ROUTING_KEY=attendance.checkin.retry
RABBITMQ_CHECKIN_DEAD_LETTER_EXCHANGE=attendance.dead
RABBITMQ_CHECKIN_DEAD_LETTER_QUEUE=attendance.checkin.dlq
RABBITMQ_CHECKIN_DEAD_LETTER_ROUTING_KEY=attendance.checkin.failed
RABBITMQ_CHECKIN_MAX_RETRIES=3
RABBITMQ_CHECKIN_RETRY_DELAY_MS=5000

# RabbitMQ Sync
RABBITMQ_REGISTRATION_SYNC_EXCHANGE=registration.sync.events
RABBITMQ_REGISTRATION_SYNC_QUEUE=registration.sync.queue
RABBITMQ_REGISTRATION_SYNC_ROUTING_KEY=registration.sync.requested

# QR Attendance Settings
QR_SESSION_TTL_BUFFER_SECONDS=300
QR_DUPLICATE_PENDING_TTL_SECONDS=120
QR_DUPLICATE_COMPLETED_TTL_SECONDS=86400
QR_CHECKIN_LOCK_TTL_SECONDS=30
QR_DEFAULT_WINDOW_SECONDS=30
QR_MAX_WINDOWS_PER_SESSION=720

# CORS
CORS_ALLOW_ORIGINS=http://localhost,http://api.localhost,http://qr.localhost