# ── API Server ─────────────────────────────────────────────
BACKEND_HOST_PORT=8001

# ── MongoDB (DB riêng cho QR Service, port 27018 tránh xung đột với BE) ──
MONGO_HOST_PORT=27018
MONGO_DATABASE=qr_attendance_db
MONGO_INITDB_ROOT_USERNAME=qr_admin
MONGO_INITDB_ROOT_PASSWORD=change_me_qr_password
REDIS_HOST_PORT=6380
REDIS_DB=0
REDIS_PASSWORD=

# ── JWT (Dùng chung secret với BE để xác thực token của user) ──
JWT_SECRET=change_me_jwt_secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ────────────────────────────────────────────────────
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── RabbitMQ (kết nối vào container ttcs_rabbitmq ở ttcs_shared network) ──
RABBITMQ_HOST=ttcs_rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
RABBITMQ_PREFETCH_COUNT=20

# ── Registration Sync Exchange/Queue ────────────────────────
RABBITMQ_REGISTRATION_SYNC_EXCHANGE=registration.sync.events
RABBITMQ_REGISTRATION_SYNC_QUEUE=registration.sync.queue
RABBITMQ_REGISTRATION_SYNC_ROUTING_KEY=registration.sync.requested
RABBITMQ_CHECKIN_SYNC_EXCHANGE=attendance.sync.events
RABBITMQ_CHECKIN_SYNC_QUEUE=attendance.sync.queue
RABBITMQ_CHECKIN_SYNC_ROUTING_KEY=attendance.checkin.completed
